{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunity_id",
    "title",
    "summary",
    "taxonomy_scope",
    "demand_signal_score",
    "supply_gap_score",
    "validation_score",
    "confidence",
    "evidence",
    "generated_at",
    "schema_version"
  ],
  "properties": {
    "opportunity_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "summary": {
      "type": "string",
      "minLength": 12
    },
    "taxonomy_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["need_state", "occasion", "format", "audience"],
      "properties": {
        "need_state": {
          "type": "string",
          "minLength": 1
        },
        "occasion": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "demand_signal_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supply_gap_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "validation_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "kind",
          "summary",
          "source_record_ids",
          "confidence"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "supply_gap",
              "demand_signal",
              "behavior_signal",
              "brand_signal",
              "validation_note"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 8
          },
          "source_record_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
