{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaxonomyAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "listing_id",
    "taxonomy_version",
    "axes",
    "confidence",
    "assigned_at"
  ],
  "properties": {
    "listing_id": {
      "type": "string",
      "minLength": 1
    },
    "taxonomy_version": {
      "type": "string",
      "minLength": 1
    },
    "axes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["need_state", "occasion", "format", "audience"],
      "properties": {
        "need_state": {
          "type": "string",
          "minLength": 1
        },
        "occasion": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adjacent_categories": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "assigned_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
