{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawSourceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "source",
    "snapshot_id",
    "captured_at",
    "payload"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "minLength": 1
    },
    "cursor": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}
