{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "kind",
    "summary",
    "source_record_ids",
    "confidence"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "supply_gap",
        "demand_signal",
        "behavior_signal",
        "brand_signal",
        "validation_note"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 8
    },
    "source_record_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
