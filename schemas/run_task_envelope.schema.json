{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunTaskEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "task_type",
    "repo_sha",
    "owner_agent",
    "status",
    "dependencies",
    "input_artifact_uris",
    "acceptance_checks",
    "retry_budget",
    "timeout_seconds"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "minLength": 1
    },
    "repo_sha": {
      "type": "string",
      "minLength": 1
    },
    "owner_agent": {
      "type": "string",
      "enum": ["planner", "executor", "validator", "memory"]
    },
    "status": {
      "type": "string",
      "enum": ["queued", "ready", "running", "validated", "failed", "blocked"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_artifact_uris": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    }
  }
}
