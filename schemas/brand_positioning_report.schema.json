{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BrandPositioningReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "status",
    "total_products",
    "archetype_counts",
    "market_themes",
    "records",
    "caveats"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial_success", "failed"]
    },
    "total_products": {
      "type": "integer",
      "minimum": 0
    },
    "archetype_counts": {
      "type": "object"
    },
    "market_themes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
