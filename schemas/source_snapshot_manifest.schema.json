{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceSnapshotManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "source",
    "captured_at",
    "record_count",
    "record_ids",
    "storage_uri"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "minLength": 1
    },
    "record_count": {
      "type": "integer",
      "minimum": 0
    },
    "record_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "storage_uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
