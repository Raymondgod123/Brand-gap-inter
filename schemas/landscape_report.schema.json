{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LandscapeReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "status",
    "product_count",
    "competitors",
    "price_ladder",
    "rating_ladder",
    "review_ladder",
    "claim_patterns",
    "caveats"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial_success", "failed"]
    },
    "product_count": {
      "type": "integer",
      "minimum": 0
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "price_ladder": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rating_ladder": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "review_ladder": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "claim_patterns": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
