{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NormalizedListing",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "listing_id",
    "source",
    "source_record_id",
    "captured_at",
    "product_title",
    "brand_name",
    "category_path",
    "price",
    "currency",
    "unit_price",
    "unit_measure",
    "pack_count",
    "availability",
    "raw_payload_uri"
  ],
  "properties": {
    "listing_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["amazon", "walmart", "target", "shopify", "manual"]
    },
    "source_record_id": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "minLength": 1
    },
    "product_title": {
      "type": "string",
      "minLength": 3
    },
    "brand_name": {
      "type": "string",
      "minLength": 1
    },
    "category_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "price": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3
    },
    "unit_price": {
      "type": "number",
      "minimum": 0
    },
    "unit_measure": {
      "type": "string",
      "enum": ["count", "oz", "lb", "g", "kg", "ml", "l"]
    },
    "pack_count": {
      "type": "integer",
      "minimum": 1
    },
    "availability": {
      "type": "string",
      "enum": ["in_stock", "out_of_stock", "limited", "unknown"]
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "review_count": {
      "type": "integer",
      "minimum": 0
    },
    "raw_payload_uri": {
      "type": "string",
      "minLength": 1
    }
  }
}
